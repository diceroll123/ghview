"│                                                                                                                      █"
"│• [Quickstart]                                                                                                        █"
"│• [Documentation]                                                                                                     █"
"│• [Examples]                                                                                                          █"
"│• [Contributing]                                                                                                      ║"
"│• [License]                                                                                                           ║"
"│## Quickstart                                                                                                         ║"
"│                                                                                                                      ║"
"│Add the crate to your project:                                                                                        ║"
"│                                                                                                                      ║"
"│                                                                                                                      ║"
"│cargo add noop-svc                                                                                                    ║"
"│                                                                                                                      ║"
"│A minimal server looks like this:                                                                                     ║"
"│                                                                                                                      ║"
"│                                                                                                                      ║"
"│use noop_svc::Server;                                                                                                 ║"
"│                                                                                                                      ║"
"│#[tokio::main]                                                                                                        ║"
"│async fn main() -> anyhow::Result<()> {                                                                               ║"
"│    Server::bind("0.0.0.0:8080")                                                                                      ║"
"│        .respond_with_nothing()                                                                                       ║"
"│        .serve()                                                                                                      ║"
"│        .await                                                                                                        ║"
"│}                                                                                                                     ║"
"│                                                                                                                      ║"
